[Unit]
Description=Door Sensor Monitor — TF-Luna LiDAR to CloudWatch
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/hitl-tools/src
ExecStart=/usr/bin/python3 /opt/hitl-tools/src/door_sensor.py --config /etc/door-monitor/door_monitor.ini --device /dev/ttyACM0
Restart=on-failure
RestartSec=10
StandardOutput=journal
StandardError=journal

# Ensure the service can access the serial device
SupplementaryGroups=dialout

# Hardening
ProtectSystem=strict
ReadWritePaths=/opt/hitl-tools/src
PrivateTmp=true

[Install]
WantedBy=multi-user.target
