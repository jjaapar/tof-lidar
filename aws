import boto3

# Create STS client
sts_client = boto3.client('sts')

# Try to assume the role
response = sts_client.assume_role(
    RoleArn='arn:aws:iam::448355772178:role/plexus-venue-health-check-cloudwatch-role',
    RoleSessionName='test-session'
)

key_path = /home/labuser/.ssh/id_ecdsa

# SSH connection timeout in seconds
timeout = 10

[commands]
# Command to execute when door opens (normal mode)
#door_open = echo "Door opened at $(date)" >> /tmp/door_events.log && /opt/hitl-tools/src/light_control.py BLINK_RED && bash -ic "source /opt/hitl-tools/.manage_bashrc_functions && powercycle chroma --power-off"
door_open = /opt/hitl-tools/src/door_event_handler.sh active

# Command to execute when door closes
door_closed = echo "Door closed at $(date)" >> /tmp/door_events.log

# Command to execute when door opens in maintenance mode
door_open_maint = /opt/hitl-tools/src/door_event_handler.sh maintenance

[monitoring]
# Delay between sensor checks in seconds
alert_delay = 0.5

# Debounce delay to avoid false triggers in seconds
debounce_delay = 1.0

[cloudwatch]
# Enable CloudWatch logging and metrics (True/False)
enabled = True

# AWS IAM role ARN to assume for CloudWatch access
aws_role = arn:aws:iam::448355772178:role/plexus-venue-health-check-cloudwatch-role

# AWS region
aws_region = us-west-2

# CloudWatch namespace for metrics
namespace = DoorStateMonitoring

# CloudWatch Logs log group name
log_group = door-sensor

# CloudWatch Logs log stream name
log_stream = door-events

# Door location identifier (used as dimension in metrics)
door_location = ChamberDoor

# Device identifier (used as dimension in metrics)
device_id = rad-sat-02-door-sensor-01

# Role duration timeout
credential_duration = 3000
